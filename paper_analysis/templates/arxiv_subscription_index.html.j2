<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>arXiv 订阅历史列表</title>
    <style>
      :root {
        color-scheme: light;
        --bg: #f4efe7;
        --panel: #fffcf7;
        --ink: #1f1d1a;
        --muted: #6a645d;
        --line: #dacdbc;
      }
      body {
        margin: 0;
        font-family: "Microsoft YaHei UI", "PingFang SC", sans-serif;
        background: linear-gradient(180deg, #fff7ec 0%, var(--bg) 100%);
        color: var(--ink);
      }
      main {
        max-width: 920px;
        margin: 0 auto;
        padding: 28px 18px 48px;
      }
      .panel {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 18px 20px;
        margin-bottom: 16px;
      }
      table {
        width: 100%;
        border-collapse: collapse;
      }
      th,
      td {
        padding: 12px 8px;
        border-bottom: 1px solid var(--line);
        text-align: left;
      }
      .muted {
        color: var(--muted);
      }
      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }
      .actions a {
        color: #9f4a1d;
        text-decoration: none;
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 4px 10px;
        background: #fbf3e8;
      }
      .actions a:hover {
        background: #f5e7d2;
      }
      code {
        background: #efe3d4;
        border-radius: 8px;
        padding: 2px 6px;
      }
    </style>
  </head>
  <body>
    <main>
      <section class="panel">
        <h1>arXiv 订阅历史列表</h1>
        <p class="muted">当前展示最近 {{ history_limit }} 次运行。最新 run_id：<code>{{ snapshot.run_id }}</code></p>
        <p class="muted">最新页位于 <code>latest.html</code>，当前记录与邮件共用同一份运行快照。</p>
      </section>
      <section class="panel">
        <table>
          <thead>
            <tr>
              <th>订阅日期</th>
              <th>运行时间</th>
              <th>抓取 / 推荐</th>
              <th>邮件</th>
              <th>站点</th>
              <th>页面地址</th>
            </tr>
          </thead>
          <tbody>
            {% for item in history_entries %}
            <tr data-run-id="{{ item.run_id }}">
              <td>{{ item.subscription_date }}</td>
              <td>{{ item.generated_at }}</td>
              <td>{{ item.fetched_count }} / {{ item.recommended_count }}</td>
              <td>{{ item.email_status }}</td>
              <td>{{ item.site_status }}</td>
              <td>
                <div class="actions">
                  <a href="{{ item.run_page_href }}">运行页</a>
                  <a href="{{ item.email_page_href }}">邮件HTML</a>
                  <a href="{{ item.snapshot_href }}">快照JSON</a>
                </div>
              </td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </section>
    </main>
  </body>
</html>
