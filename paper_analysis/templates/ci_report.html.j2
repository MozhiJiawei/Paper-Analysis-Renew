<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <title>{{ title }}</title>
  <style>
    :root {
      color-scheme: light;
      --bg: #f5f1e8;
      --panel: #fffdf8;
      --card: #fffaf1;
      --text: #1f2a28;
      --muted: #5d6a67;
      --border: #d6c9b8;
      --passed: #1d6b43;
      --failed: #ab2f2f;
      --warning: #a05a00;
      --skipped: #8a6d1f;
      --missing: #7d4f9e;
      --code: #f2ece1;
      --chip-bg: #f7efe3;
      --chip-active: #efe2cd;
    }

    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: "Microsoft YaHei", "PingFang SC", sans-serif;
      background: linear-gradient(180deg, #ede4d5 0%, var(--bg) 280px);
      color: var(--text);
      line-height: 1.6;
    }
    main {
      max-width: 1240px;
      margin: 0 auto;
      padding: 32px 20px 48px;
    }
    .hero, .panel {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 18px;
      box-shadow: 0 10px 30px rgba(98, 73, 43, 0.08);
      padding: 24px;
    }
    .hero { margin-bottom: 20px; }
    .hero h1 { margin: 0 0 8px; font-size: 32px; }
    .hero p, .muted { color: var(--muted); }
    .panel + .panel { margin-top: 20px; }
    .status, .pill {
      display: inline-block;
      border-radius: 999px;
      border: 1px solid currentColor;
      font-weight: 700;
      background: #efe7d7;
    }
    .status {
      margin-top: 14px;
      padding: 6px 12px;
    }
    .pill {
      padding: 2px 10px;
      font-size: 13px;
    }
    .status-passed { color: var(--passed); }
    .status-failed { color: var(--failed); }
    .status-warning { color: var(--warning); }
    .status-skipped { color: var(--skipped); }
    .status-missing { color: var(--missing); }
    .kpi {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 16px;
    }
    .kpi span {
      background: #f8f3ea;
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 8px 12px;
    }
    .category-header {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 16px;
    }
    .case-layout, .stage-grid, .report-grid {
      display: grid;
      gap: 18px;
    }
    .case-layout {
      grid-template-columns: 1fr;
      margin-top: 18px;
    }
    .case-toolbar {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      align-items: center;
    }
    .case-search {
      flex: 1 1 260px;
      min-height: 40px;
      padding: 8px 12px;
      border: 1px solid var(--border);
      border-radius: 12px;
      background: #fffaf1;
      color: var(--text);
    }
    .filter-group {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    .filter-chip {
      border: 1px solid var(--border);
      border-radius: 999px;
      background: #f8f1e6;
      color: var(--text);
      padding: 7px 12px;
      cursor: pointer;
      font-size: 13px;
      font-weight: 700;
    }
    .filter-chip.is-active {
      background: #ebdfca;
      border-color: #c5a06f;
    }
    .case-list {
      border: 1px solid #eadfce;
      border-radius: 16px;
      background: #fffaf2;
      overflow: hidden;
    }
    .case-list-inner {
      max-height: 320px;
      overflow-y: auto;
    }
    .case-tab {
      display: flex;
      gap: 10px;
      align-items: center;
      width: 100%;
      min-height: 38px;
      padding: 9px 12px;
      border: 0;
      border-bottom: 1px solid #efe4d3;
      background: var(--chip-bg);
      color: var(--text);
      text-align: left;
      cursor: pointer;
    }
    .case-tab:last-child {
      border-bottom: 0;
    }
    .case-tab.is-active {
      background: var(--chip-active);
      box-shadow: inset 3px 0 0 rgba(143, 92, 35, 0.45);
    }
    .case-tab.is-hidden {
      display: none;
    }
    .case-light {
      flex: 0 0 10px;
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: currentColor;
      box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.05);
    }
    .case-tab-body {
      display: flex;
      gap: 8px;
      align-items: center;
      min-width: 0;
      width: 100%;
    }
    .case-tab-title {
      min-width: 0;
      flex: 1;
      font-size: 13px;
      font-weight: 700;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .case-tab-status {
      flex: 0 0 auto;
      font-size: 11px;
      font-weight: 700;
    }
    .tag {
      display: inline-block;
      padding: 2px 10px;
      border-radius: 999px;
      background: #f3ebdd;
      border: 1px solid var(--border);
      font-size: 12px;
    }
    .card, .case-detail {
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 18px;
      background: var(--card);
      min-width: 0;
    }
    .card h3, .case-detail h3 {
      margin: 0 0 8px;
      overflow-wrap: anywhere;
      word-break: break-word;
    }
    .card p, .case-detail p {
      margin: 8px 0;
      overflow-wrap: anywhere;
      word-break: break-word;
    }
    .meta-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
      margin-bottom: 10px;
    }
    .case-panel {
      display: none;
    }
    .case-panel.is-active {
      display: block;
    }
    .case-panel.is-hidden {
      display: none !important;
    }
    .case-detail-block + .case-detail-block {
      margin-top: 12px;
    }
    a.local-link {
      color: #8b3f1f;
      text-decoration: none;
      border-bottom: 1px dashed currentColor;
    }
    a.local-link:hover {
      color: #5d2811;
    }
    pre {
      white-space: pre-wrap;
      word-break: break-word;
      background: var(--code);
      border: 1px solid #e4d8c6;
      border-radius: 12px;
      padding: 14px;
      overflow-x: auto;
    }
    code { font-family: Consolas, "Courier New", monospace; }
    ul {
      margin: 8px 0 0;
      padding-left: 20px;
      min-width: 0;
    }
    li {
      overflow-wrap: anywhere;
      word-break: break-word;
    }
    li + li { margin-top: 4px; }
    details { margin-top: 14px; }
    .stage-grid {
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    }
    .report-grid {
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 12px;
    }
    th, td {
      text-align: left;
      padding: 10px 8px;
      border-bottom: 1px solid #eadfce;
      vertical-align: top;
      overflow-wrap: anywhere;
      word-break: break-word;
    }
  </style>
</head>
<body>
  <main>
    <section class="hero">
      <h1>{{ title }}</h1>
      <p>三大类保持大框结构；每类内部改成紧凑列表、失败优先、单详情区，便于 100~200 个用例时快速定位异常项。</p>
      <div class="status status-{{ overall_status }}">整体结果：{{ overall_status_label }}</div>
      <div class="kpi">
        <span>阶段数：{{ total_stages }}</span>
        <span>用例数：{{ total_cases }}</span>
        <span>阶段通过：{{ passed_count }}</span>
        <span>阶段失败：{{ failed_count }}</span>
        <span>用例告警：{{ warning_count }}</span>
        <span>阶段未执行：{{ skipped_count }}</span>
      </div>
    </section>

    {% for category in case_categories %}
    <section class="panel">
      <div class="category-header">
        <div>
          <h2>{{ category.label }}</h2>
          <p class="muted">默认展示当前筛选后的第一个用例；失败和未执行会自动排在前面。</p>
        </div>
        <div>
          <span class="pill status-{{ category.status }}">{{ category.status_label }}</span>
        </div>
      </div>
      <div class="kpi">
        <span>总数：{{ category.total_count }}</span>
        <span>通过：{{ category.passed_count }}</span>
        <span>失败：{{ category.failed_count }}</span>
        <span>告警：{{ category.warning_count }}</span>
        <span>未执行：{{ category.skipped_count }}</span>
      </div>

      <div class="case-layout" data-case-tabs="{{ category.category_key }}">
        <div class="case-toolbar">
          <input
            class="case-search"
            type="search"
            placeholder="搜索标题、描述或来源标签"
            data-case-search
          >
          <div class="filter-group">
            <button type="button" class="filter-chip is-active" data-status-filter="all">全部</button>
            <button type="button" class="filter-chip" data-status-filter="failed">失败</button>
            <button type="button" class="filter-chip" data-status-filter="warning">告警</button>
            <button type="button" class="filter-chip" data-status-filter="skipped">未执行</button>
            <button type="button" class="filter-chip" data-status-filter="passed">通过</button>
          </div>
        </div>

        <div class="case-list">
          <div class="case-list-inner" role="tablist" aria-label="{{ category.label }}">
            {% for case in category.cases %}
            <button
              type="button"
              class="case-tab status-{{ case.status }}{% if loop.first %} is-active{% endif %}"
              data-case-target="{{ category.category_key }}-{{ loop.index0 }}"
              data-case-status="{{ case.status }}"
              data-case-search-text="{{ (case.title ~ ' ' ~ case.description ~ ' ' ~ case.source_label)|lower }}"
              role="tab"
              aria-selected="{% if loop.first %}true{% else %}false{% endif %}"
              title="{{ case.title }}"
            >
              <span class="case-light"></span>
              <span class="case-tab-body">
                <span class="case-tab-title">{{ case.title }}</span>
                <span class="case-tab-status">{{ case.status_label }}</span>
                <span class="tag">{{ case.source_label }}</span>
              </span>
            </button>
            {% endfor %}
          </div>
        </div>

        {% for case in category.cases %}
        <section
          class="case-panel{% if loop.first %} is-active{% endif %}"
          data-case-panel="{{ category.category_key }}-{{ loop.index0 }}"
          data-case-status="{{ case.status }}"
          data-case-search-text="{{ (case.title ~ ' ' ~ case.description ~ ' ' ~ case.source_label)|lower }}"
        >
          <div class="case-detail">
            <div class="meta-row">
              <span class="pill status-{{ case.status }}">{{ case.status_label }}</span>
              <span class="tag">{{ case.source_label }}</span>
            </div>
            <h3>{{ case.title }}</h3>
            {% if case.script_link.href %}
            <div class="case-detail-block">
              <strong>测试脚本：</strong><a class="local-link" href="{{ case.script_link.href }}">{{ case.script_link.label }}</a>
            </div>
            {% endif %}
            <div class="case-detail-block">
              <strong>用例描述：</strong>{{ case.description }}
            </div>
            <div class="case-detail-block">
              <strong>失败判定：</strong>{{ case.failure_check }}
            </div>
            {% if case.artifact_links %}
            <div class="case-detail-block">
              <strong>关联产物：</strong>
              <ul>
                {% for artifact in case.artifact_links %}
                <li><a class="local-link" href="{{ artifact.href }}">{{ artifact.label }}</a></li>
                {% endfor %}
              </ul>
            </div>
            {% endif %}
            <details open>
              <summary>用例过程</summary>
              <ul>
                {% for line in case.process_log %}
                <li>{{ line }}</li>
                {% endfor %}
              </ul>
            </details>
            <details>
              <summary>结果日志</summary>
              <pre>{{ case.result_log }}</pre>
            </details>
          </div>
        </section>
        {% endfor %}
      </div>
    </section>
    {% endfor %}

    <section class="panel">
      <h2>阶段概览</h2>
      <p class="muted">保留阶段级汇总，便于追查完整 stdout/stderr。</p>
      <div class="stage-grid">
        {% for result in stage_results %}
        <article class="card">
          <div class="meta-row">
            <span class="pill status-{{ result.status }}">{{ result.status_label }}</span>
            <span class="tag">{{ result.stage_name }}</span>
          </div>
          <h3>{{ result.stage_name }}</h3>
          <p>{{ result.description }}</p>
          <p><strong>摘要：</strong>{{ result.summary }}</p>
          <p><strong>Artifact：</strong><code>{{ result.artifact_path }}</code></p>
          <details>
            <summary>查看阶段输出</summary>
            <pre>{{ result.output }}</pre>
          </details>
        </article>
        {% endfor %}
      </div>
    </section>

    <section class="panel">
      <h2>E2E 报告附件</h2>
      <p class="muted">保留顶会与 arXiv 结构化报告，便于继续审阅推荐结果。</p>
      <div class="report-grid">
        {% for section in e2e_sections %}
        <article class="card">
          <div class="meta-row">
            <span class="pill status-{{ section.status }}">{{ section.status_label }}</span>
            <span class="tag">{{ section.source_name }}</span>
          </div>
          <h3>{{ section.source_name }}报告</h3>
          <p><strong>目录：</strong><code>{{ section.report_dir }}</code></p>
          <p><strong>推荐数量：</strong>{{ section.count }}</p>
          {% if section.note %}
          <p><strong>说明：</strong>{{ section.note }}</p>
          {% endif %}
          <table>
            <thead>
              <tr>
                <th>标题</th>
                <th>作者</th>
                <th>机构</th>
                <th>来源</th>
                <th>原因</th>
              </tr>
            </thead>
            <tbody>
              {% if section.papers %}
                {% for paper in section.papers %}
                <tr>
                  <td>{{ paper.get("title", "") }}</td>
                  <td>{{ paper.get("authors", "") }}</td>
                  <td>{{ paper.get("organization", "") }}</td>
                  <td>{{ paper.get("venue", paper.get("source", "")) }}</td>
                  <td>
                    {% set reasons = paper.get("reasons", []) %}
                    {% if reasons %}
                      {{ "；".join(reasons) }}
                    {% else %}
                      {{ paper.get("sampled_reason", "") or "无" }}
                    {% endif %}
                  </td>
                </tr>
                {% endfor %}
              {% else %}
                <tr>
                  <td colspan="5" class="muted">暂无可展示的推荐结果。</td>
                </tr>
              {% endif %}
            </tbody>
          </table>
          <details>
            <summary>查看 summary.md</summary>
            <pre>{{ section.summary_markdown.strip() or "无 Markdown 摘要。" }}</pre>
          </details>
          <details>
            <summary>查看 stdout.txt</summary>
            <pre>{{ section.stdout.strip() or "无 stdout 输出。" }}</pre>
          </details>
        </article>
        {% endfor %}
      </div>
    </section>
  </main>

  <script>
    (function () {
      function activate(group, target) {
        var tabs = group.querySelectorAll("[data-case-target]");
        var panels = group.querySelectorAll("[data-case-panel]");
        tabs.forEach(function (tab) {
          var active = !tab.classList.contains("is-hidden") && tab.getAttribute("data-case-target") === target;
          tab.classList.toggle("is-active", active);
          tab.setAttribute("aria-selected", active ? "true" : "false");
        });
        panels.forEach(function (panel) {
          var active = !panel.classList.contains("is-hidden") && panel.getAttribute("data-case-panel") === target;
          panel.classList.toggle("is-active", active);
        });
      }

      function firstVisibleTarget(group) {
        var visibleTab = group.querySelector("[data-case-target]:not(.is-hidden)");
        return visibleTab ? visibleTab.getAttribute("data-case-target") : "";
      }

      function applyFilters(group) {
        var searchInput = group.querySelector("[data-case-search]");
        var activeFilter = group.querySelector("[data-status-filter].is-active");
        var selectedStatus = activeFilter ? activeFilter.getAttribute("data-status-filter") : "all";
        var query = (searchInput ? searchInput.value : "").trim().toLowerCase();

        group.querySelectorAll("[data-case-target]").forEach(function (tab) {
          var matchesStatus = selectedStatus === "all" || tab.getAttribute("data-case-status") === selectedStatus;
          var matchesQuery = !query || (tab.getAttribute("data-case-search-text") || "").indexOf(query) >= 0;
          tab.classList.toggle("is-hidden", !(matchesStatus && matchesQuery));
        });

        group.querySelectorAll("[data-case-panel]").forEach(function (panel) {
          var matchesStatus = selectedStatus === "all" || panel.getAttribute("data-case-status") === selectedStatus;
          var matchesQuery = !query || (panel.getAttribute("data-case-search-text") || "").indexOf(query) >= 0;
          panel.classList.toggle("is-hidden", !(matchesStatus && matchesQuery));
          panel.classList.remove("is-active");
        });

        var nextTarget = firstVisibleTarget(group);
        if (nextTarget) {
          activate(group, nextTarget);
        }
      }

      document.querySelectorAll("[data-case-tabs]").forEach(function (group) {
        group.querySelectorAll("[data-case-target]").forEach(function (tab) {
          tab.addEventListener("click", function () {
            activate(group, tab.getAttribute("data-case-target"));
          });
        });
        group.querySelectorAll("[data-status-filter]").forEach(function (button) {
          button.addEventListener("click", function () {
            group.querySelectorAll("[data-status-filter]").forEach(function (item) {
              item.classList.remove("is-active");
            });
            button.classList.add("is-active");
            applyFilters(group);
          });
        });
        var searchInput = group.querySelector("[data-case-search]");
        if (searchInput) {
          searchInput.addEventListener("input", function () {
            applyFilters(group);
          });
        }
        applyFilters(group);
      });
    })();
  </script>
</body>
</html>
