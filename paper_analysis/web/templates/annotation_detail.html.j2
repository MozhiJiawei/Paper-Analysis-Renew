{% extends "annotation_base.html.j2" %}
{% block content %}
<div class="detail-layout detail-layout-fit" data-detail-layout>
  <section class="detail-main">
    <section class="panel compact-panel paper-panel" data-paper-panel>
      <div class="paper-meta">
        <div>
          <h2>{{ candidate.title }}</h2>
          <p class="muted">{{ candidate.venue }}</p>
        </div>
        <div class="paper-meta-badges">
          <span class="meta-badge">{{ candidate.primary_research_object }}</span>
          <span class="meta-badge">{{ candidate.source }}</span>
        </div>
      </div>
    </section>

    <section class="panel compact-panel abstract-panel" data-abstract-panel>
      <div class="section-heading">
        <h3>摘要</h3>
        <p class="muted">默认只展示中文摘要，减少首屏干扰。</p>
      </div>
      <article class="abstract-card abstract-card-single">
        <h4>中文摘要</h4>
        <div class="abstract-content abstract-content-fit" data-abstract-content>
          {% if candidate.abstract_zh %}
          <p data-abstract-text>{{ candidate.abstract_zh }}</p>
          {% else %}
          <p class="muted">暂无中文摘要</p>
          {% endif %}
        </div>
        <details class="inline-english-summary">
          <summary>查看英文摘要</summary>
          <div class="abstract-content">
            <p>{{ candidate.abstract }}</p>
          </div>
        </details>
      </article>
    </section>

    <section class="panel compact-panel ai-panel" data-ai-panel>
      <details class="collapsible-panel">
        <summary>
          <span>AI 预标</span>
          <span class="muted">默认折叠，点击展开</span>
        </summary>
        <div class="collapsible-panel-body">
          {% if ai %}
          <p><strong>主研究对象：</strong>{{ ai.primary_research_object }}</p>
          <p><strong>偏好标签：</strong>{{ ai.preference_labels|join("、") or "无" }}</p>
          <p><strong>样本极性：</strong>{{ ai.negative_tier }}</p>
          <p><strong>备注：</strong>{{ ai.notes or "无" }}</p>
          {% else %}
          <p class="muted">当前论文尚未生成 AI 预标。</p>
          {% endif %}
        </div>
      </details>
    </section>
  </section>

  <aside class="detail-side">
    <section class="panel annotation-form-panel">
        <div class="section-heading">
          <h3>人工复标</h3>
          <p class="muted">表单默认继承 AI 预标；若选择 negative，偏好标签会自动视为空。</p>
        </div>
      <form method="post" class="annotation-form">
        <div class="form-grid">
          <div>
            <label>主研究对象</label>
            <select name="primary_research_object">
              {% for item in research_object_labels %}
              <option value="{{ item }}" {% if core_seed and core_seed.primary_research_object == item %}selected{% endif %}>{{ item }}</option>
              {% endfor %}
            </select>
          </div>

          <div>
            <label>样本极性</label>
            <select name="negative_tier">
              {% for item in ["positive", "negative"] %}
              <option value="{{ item }}" {% if core_seed and core_seed.negative_tier == item %}selected{% endif %}>{{ item }}</option>
              {% endfor %}
            </select>
          </div>
        </div>

        <fieldset class="chip-fieldset">
          <legend>子偏好标签</legend>
          <p class="muted">只有 positive 样本才选择子偏好标签；现行协议要求单选，negative 样本保持不选择。</p>
          <div class="chip-grid">
            {% for label in preference_labels %}
            <label class="checkbox-chip">
              <input type="radio" name="preference_labels" value="{{ label }}" {% if preference_seed and label in preference_seed.preference_labels %}checked{% endif %}>
              <span>{{ label }}</span>
            </label>
            {% endfor %}
          </div>
        </fieldset>

        <details class="form-details">
          <summary>补充信息</summary>
          <label>证据</label>
          <textarea name="evidence_1" rows="3">{{ supplement_seed.evidence_spans.get("general", [""])[0] if supplement_seed and supplement_seed.evidence_spans.get("general") else "" }}</textarea>

          <label>备注</label>
          <textarea name="notes" rows="3">{{ supplement_seed.notes if supplement_seed else "" }}</textarea>
        </details>

        <div class="save-bar">
          <button type="submit">保存人工复标</button>
        </div>
      </form>
    </section>
  </aside>
</div>
<script>
  (function () {
    const layout = document.querySelector("[data-detail-layout]");
    const abstractContent = document.querySelector("[data-abstract-content]");
    const abstractText = document.querySelector("[data-abstract-text]");
    const tierSelect = document.querySelector('select[name="negative_tier"]');
    const preferenceInputs = Array.from(document.querySelectorAll('input[name="preference_labels"]'));

    if (!layout || !abstractContent || !abstractText) {
      return;
    }

    const fitAbstract = function () {
      if (window.innerWidth <= 1120) {
        layout.style.height = "";
        abstractText.style.fontSize = "";
        abstractText.style.lineHeight = "";
        return;
      }

      const layoutTop = layout.getBoundingClientRect().top;
      const availableHeight = Math.max(520, window.innerHeight - layoutTop - 12);
      layout.style.height = availableHeight + "px";

      let fontSize = 17;
      let lineHeight = 1.72;
      abstractText.style.fontSize = fontSize + "px";
      abstractText.style.lineHeight = String(lineHeight);

      while (abstractContent.scrollHeight > abstractContent.clientHeight + 2 && fontSize > 12) {
        fontSize -= 0.5;
        lineHeight = Math.max(1.34, lineHeight - 0.04);
        abstractText.style.fontSize = fontSize + "px";
        abstractText.style.lineHeight = String(lineHeight);
      }
    };

    window.addEventListener("load", fitAbstract);
    window.addEventListener("resize", fitAbstract);
    fitAbstract();

    const syncPreferenceInputs = function () {
      if (!tierSelect || preferenceInputs.length === 0) {
        return;
      }
      const isNegative = tierSelect.value === "negative";
      preferenceInputs.forEach(function (input) {
        if (isNegative) {
          input.checked = false;
        }
        input.disabled = isNegative;
      });
    };

    if (tierSelect) {
      tierSelect.addEventListener("change", syncPreferenceInputs);
      syncPreferenceInputs();
    }
  }());
</script>
{% endblock %}
